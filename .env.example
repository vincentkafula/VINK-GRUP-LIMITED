# Copy to .env and fill in real values before building/deploying.

# Express backend base URL (used as fallback when Supabase edge function is unavailable)
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001

# Supabase (required for auth, realtime, and edge-function API routes)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# Web push notifications
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Payments (only needed once live processing is wired up)
VITE_PEACH_MERCHANT_ID=your-merchant-id

# Maps
VITE_GOOGLE_MAPS_KEY=your-maps-key

# Analytics / monitoring
VITE_POSTHOG_KEY=your-posthog-key
VITE_SENTRY_DSN=your-sentry-dsn
